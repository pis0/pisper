# pisper - config do usuário
# Copie para ~/.config/pisper/env e preencha os valores.
# chmod 600 ~/.config/pisper/env

OPENAI_API_KEY=sk-...

# Modelo de transcrição. Opções atuais:
#   gpt-4o-transcribe      (recomendado, melhor qualidade)
#   gpt-4o-mini-transcribe (mais barato)
#   whisper-1              (legacy)
# PISPER_MODEL=gpt-4o-transcribe
