# pisper - user config
# Copy to ~/.config/pisper/env and fill in the values.
# chmod 600 ~/.config/pisper/env

OPENAI_API_KEY=sk-...

# Transcription model. Current options:
#   gpt-4o-transcribe      (recommended, best quality)
#   gpt-4o-mini-transcribe (cheaper)
#   whisper-1              (legacy)
# PISPER_MODEL=gpt-4o-transcribe

# Force transcription language (ISO-639-1 code) instead of letting the model
# auto-detect. Useful when short or noisy audio is occasionally misidentified
# (e.g. Portuguese coming back transcribed as Spanish or translated to English).
# Leave commented out to auto-detect.
# Examples: pt (Portuguese), en (English), es (Spanish), fr (French),
# de (German), ja (Japanese), zh (Chinese). Full list of codes:
# https://en.wikipedia.org/wiki/List_of_ISO_639_language_codes
# PISPER_LANGUAGE=pt
