# pisper - user config
# Copy to ~/.config/pisper/env and fill in the values.
# chmod 600 ~/.config/pisper/env

OPENAI_API_KEY=sk-...

# Transcription model. Current options:
#   gpt-4o-transcribe      (recommended, best quality)
#   gpt-4o-mini-transcribe (cheaper)
#   whisper-1              (legacy)
# PISPER_MODEL=gpt-4o-transcribe
