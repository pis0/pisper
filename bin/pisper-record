#!/usr/bin/env bash
# pisper-record: inicia gravação do mic em background via ffmpeg/AVFoundation.
# Chamado pelo Hammerspoon on keyDown do atalho configurado.
set -euo pipefail
umask 077

# Hammerspoon spawna shell não-interativo — PATH mínimo sem brew.
export PATH="/opt/homebrew/bin:/usr/local/bin:/opt/local/bin:$PATH"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

# $TMPDIR no macOS já é per-user (/var/folders/.../T/) — evita exposição em /tmp compartilhado.
PISPER_TMP="${TMPDIR:-/tmp}/pisper"
mkdir -m 700 -p "$PISPER_TMP"

AUDIO_FILE="$PISPER_TMP/recording.wav"
PID_FILE="$PISPER_TMP/ffmpeg.pid"
LOG_FILE="$PISPER_TMP/record.log"

if [[ -f "$PID_FILE" ]]; then
  old_pid=$(cat "$PID_FILE" 2>/dev/null || echo "")
  rm -f "$PID_FILE"
  # Só mata se o processo ainda é ffmpeg — PID pode ter sido reciclado.
  if [[ -n "$old_pid" ]] && [[ "$(ps -p "$old_pid" -o comm= 2>/dev/null)" == *ffmpeg* ]]; then
    kill "$old_pid" 2>/dev/null || true
    sleep 0.1
  fi
fi

rm -f "$AUDIO_FILE"

ffmpeg -hide_banner -loglevel error \
  -f avfoundation -i ":default" \
  -ar 16000 -ac 1 -y "$AUDIO_FILE" \
  </dev/null >"$LOG_FILE" 2>&1 &

echo $! > "$PID_FILE"
