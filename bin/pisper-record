#!/usr/bin/env bash
# pisper-record: starts background mic capture via ffmpeg/AVFoundation.
# Called by Hammerspoon on keyDown of the configured hotkey.
# Usage: pisper-record <session_id>
set -euo pipefail
umask 077

export PATH="/opt/homebrew/bin:/usr/local/bin:/opt/local/bin:$PATH"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

SESSION="${1:-default}"
# Strip anything suspicious from the session id (defensive — alnum + dash only).
SESSION="${SESSION//[^A-Za-z0-9_-]/}"
[[ -z "$SESSION" ]] && SESSION="default"

# $TMPDIR on macOS is already per-user — avoids exposure in a shared /tmp.
PISPER_TMP="${TMPDIR:-/tmp}/pisper"
mkdir -m 700 -p "$PISPER_TMP"

AUDIO_FILE="$PISPER_TMP/rec-$SESSION.wav"
PID_FILE="$PISPER_TMP/ffmpeg-$SESSION.pid"
LOG_FILE="$PISPER_TMP/record-$SESSION.log"

rm -f "$AUDIO_FILE" "$PID_FILE"

ffmpeg -hide_banner -loglevel error \
  -f avfoundation -i ":default" \
  -ar 16000 -ac 1 -y "$AUDIO_FILE" \
  </dev/null >"$LOG_FILE" 2>&1 &
FFMPEG_PID=$!

# Verify ffmpeg actually launched — without this, a mic failure leaves the Lua
# state machine stuck in "recording" with no process to stop.
sleep 0.15
if ! kill -0 "$FFMPEG_PID" 2>/dev/null; then
  rm -f "$AUDIO_FILE"
  echo "[pisper] ffmpeg failed to start" >&2
  tail -n 5 "$LOG_FILE" >&2 2>/dev/null || true
  exit 1
fi

# Fingerprint the process to resist PID recycling. `lstart` is the process
# start timestamp — the kernel never reassigns a PID with the same lstart, so
# (PID, lstart) uniquely identifies this specific ffmpeg instance. LC_ALL=C
# pins the date format (otherwise it varies by locale). awk collapses runs
# of whitespace so comparisons are stable.
FINGERPRINT=$(LC_ALL=C ps -p "$FFMPEG_PID" -o lstart= 2>/dev/null | awk '{$1=$1; print}')
if [[ -z "$FINGERPRINT" ]]; then
  kill -KILL "$FFMPEG_PID" 2>/dev/null || true
  rm -f "$AUDIO_FILE"
  echo "[pisper] failed to fingerprint ffmpeg (pid $FFMPEG_PID)" >&2
  exit 1
fi

# Atomic write — rename only after the final file is complete. A reader never
# sees a pid-file that contains only the PID with the fingerprint missing.
TMP_PID_FILE="$PID_FILE.new"
printf '%s\n%s\n' "$FFMPEG_PID" "$FINGERPRINT" > "$TMP_PID_FILE"
mv "$TMP_PID_FILE" "$PID_FILE"
