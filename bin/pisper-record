#!/usr/bin/env bash
# pisper-record: inicia gravação do mic em background via ffmpeg/AVFoundation.
# Chamado pelo Hammerspoon on keyDown do atalho configurado.
# Uso: pisper-record <session_id>
set -euo pipefail
umask 077

export PATH="/opt/homebrew/bin:/usr/local/bin:/opt/local/bin:$PATH"
export LANG="en_US.UTF-8"
export LC_ALL="en_US.UTF-8"

SESSION="${1:-default}"
# Remove qualquer char suspeito no session id (defensivo — só alfanum+dash).
SESSION="${SESSION//[^A-Za-z0-9_-]/}"
[[ -z "$SESSION" ]] && SESSION="default"

# $TMPDIR no macOS já é per-user — evita exposição em /tmp compartilhado.
PISPER_TMP="${TMPDIR:-/tmp}/pisper"
mkdir -m 700 -p "$PISPER_TMP"

AUDIO_FILE="$PISPER_TMP/rec-$SESSION.wav"
PID_FILE="$PISPER_TMP/ffmpeg-$SESSION.pid"
LOG_FILE="$PISPER_TMP/record-$SESSION.log"

rm -f "$AUDIO_FILE" "$PID_FILE"

ffmpeg -hide_banner -loglevel error \
  -f avfoundation -i ":default" \
  -ar 16000 -ac 1 -y "$AUDIO_FILE" \
  </dev/null >"$LOG_FILE" 2>&1 &
FFMPEG_PID=$!

# Valida que ffmpeg subiu — sem isso, falha de mic deixa estado Lua inconsistente.
sleep 0.15
if ! kill -0 "$FFMPEG_PID" 2>/dev/null; then
  rm -f "$AUDIO_FILE"
  echo "[pisper] ffmpeg failed to start" >&2
  tail -n 5 "$LOG_FILE" >&2 2>/dev/null || true
  exit 1
fi

# Fingerprint do processo pra resistir a PID recycling. `lstart` é o timestamp
# de início do processo — o kernel nunca reatribui um PID com mesmo lstart,
# então (PID, lstart) identifica unicamente esta instância. LC_ALL=C trava o
# formato da data, caso contrário varia com locale. awk normaliza espaços.
FINGERPRINT=$(LC_ALL=C ps -p "$FFMPEG_PID" -o lstart= 2>/dev/null | awk '{$1=$1; print}')
if [[ -z "$FINGERPRINT" ]]; then
  kill -KILL "$FFMPEG_PID" 2>/dev/null || true
  rm -f "$AUDIO_FILE"
  echo "[pisper] failed to fingerprint ffmpeg (pid $FFMPEG_PID)" >&2
  exit 1
fi

# Escrita atômica — rename só depois que o arquivo final tá completo. Leitor
# nunca vê pid-file com só o PID e fingerprint faltando.
TMP_PID_FILE="$PID_FILE.new"
printf '%s\n%s\n' "$FFMPEG_PID" "$FINGERPRINT" > "$TMP_PID_FILE"
mv "$TMP_PID_FILE" "$PID_FILE"
